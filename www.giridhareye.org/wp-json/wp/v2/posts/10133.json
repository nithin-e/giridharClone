i2026.com\/\">https:\/\/opai2026.com\/<\/a><\/p>\n","protected":false},"excerpt":{"rendered":"<p>Discover. Learn. Collaborate at OPAI 2026 The 36th Annual Oculoplastics [&hellip;]<\/p>\n","protected":false},"author":1,"featured_media":10180,"comment_status":"open","ping_status":"open","sticky":false,"template":"","format":"standard","meta":{"_monsterinsights_skip_tracking":false,"_monsterinsights_sitenote_active":false,"_monsterinsights_sitenote_note":"","_monsterinsights_sitenote_category":0,"_uf_show_specific_survey":0,"_uf_disable_surveys":false,"footnotes":""},"categories":[137],"tags":[],"class_list":["post-10133","post","type-post","status-publish","format-standard","has-post-thumbnail","hentry","category-events"],"_links":{"self":[{"href":"https:\/\/www.giridhareye.org\/wp-json\/wp\/v2\/posts\/10133","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/www.giridhareye.org\/wp-json\/wp\/v2\/posts"}],"about":[{"href":"https:\/\/www.giridhareye.org\/wp-json\/wp\/v2\/types\/post"}],"author":[{"embeddable":true,"href":"https:\/\/www.giridhareye.org\/wp-json\/wp\/v2\/users\/1"}],"replies":[{"embeddable":true,"href":"https:\/\/www.giridhareye.org\/wp-json\/wp\/v2\/comments?post=10133"}],"version-history":[{"count":4,"href":"https:\/\/www.giridhareye.org\/wp-json\/wp\/v2\/posts\/10133\/revisions"}],"predecessor-version":[{"id":10177,"href":"https:\/\/www.giridhareye.org\/wp-json\/wp\/v2\/posts\/10133\/revisions\/10177"}],"wp:featuredmedia":[{"embeddable":true,"href":"https:\/\/www.giridhareye.org\/wp-json\/wp\/v2\/media\/10180"}],"wp:attachment":[{"href":"https:\/\/www.giridhareye.org\/wp-json\/wp\/v2\/media?parent=10133"}],"wp:term":[{"taxonomy":"category","embeddable":true,"href":"https:\/\/www.giridhareye.org\/wp-json\/wp\/v2\/categories?post=10133"},{"taxonomy":"post_tag","embeddable":true,"href":"https:\/\/www.giridhareye.org\/wp-json\/wp\/v2\/tags?post=10133"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}